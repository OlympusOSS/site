{
	"name": "site",
	"version": "1.1.13",
	"private": true,
	"description": "Olympus brochure site and OAuth2 playground",
	"scripts": {
		"gen": "node scripts/gen/index.mjs",
		"prebuild": "npm run gen",
		"postinstall": "[ -e .canvas-local ] || ln -sfn ../canvas .canvas-local; [ -d .canvas-local ] && rm -rf node_modules/@olympusoss/canvas && ln -sfn ../../.canvas-local node_modules/@olympusoss/canvas; true",
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"snapshot-coverage": "node scripts/check-snapshot-coverage.mjs",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/OlympusOSS/site.git"
	},
	"dependencies": {
		"@nivo/core": "^0.99.0",
		"@nivo/line": "^0.99.0",
		"@nivo/pie": "^0.99.0",
		"@olympusoss/canvas": "link:@olympusoss/canvas",
		"@rjsf/core": "^6.5.2",
		"@rjsf/utils": "^6.5.2",
		"@rjsf/validator-ajv8": "^6.5.2",
		"@tailwindcss/postcss": "^4.2.0",
		"@types/mdx": "^2.0.13",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"framer-motion": "^12.34.2",
		"fumadocs-core": "^16.8.0",
		"fumadocs-mdx": "^14.3.1",
		"fumadocs-ui": "^16.8.0",
		"libphonenumber-js": "^1.13.0",
		"lucide-react": "^0.577.0",
		"mermaid": "^11.15.0",
		"next": "^16.1.6",
		"postcss": "^8.5.6",
		"radix-ui": "^1.4.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.0",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.59.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/d3-geo": "^3.1.0",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.3.3",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/react-grid-layout": "1.3.6",
		"@types/react-simple-maps": "^3.0.6",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.6",
		"jsdom": "^29.1.1",
		"typescript": "^5.7.0",
		"unist-util-visit": "^5.1.0",
		"vitest": "^4.1.6"
	}
}
