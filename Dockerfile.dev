FROM oven/bun:1-alpine

WORKDIR /app

# Install system dependencies
RUN apk --no-cache add curl git

# Copy Canvas package first (at /Canvas so file:../Canvas resolves from /app)
COPY Canvas/package.json /Canvas/package.json
COPY Canvas/src /Canvas/src

# Copy package files and install dependencies
COPY demo/package.json demo/bun.lock ./
RUN bun install

# Copy source code
COPY demo/src ./src
COPY demo/next.config.js demo/tsconfig.json demo/tailwind.config.js demo/postcss.config.mjs ./

# Expose port
EXPOSE 3000

# Start development server
CMD ["bun", "run", "dev"]
